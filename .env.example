HONESTLY_DATA_PROVIDER=mock
HONESTLY_SEARCH_PROVIDER=database
# Production: set to your deployed origin (no trailing path), e.g. https://your-app.vercel.app
# Must match Supabase Auth "Site URL" / redirect allow list for Google OAuth callbacks.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
# Publishable (preferred) or anon key from Supabase — either works:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
MEILISEARCH_ADMIN_API_KEY=
HONESTLY_SEARCH_SYNC_TOKEN=
